<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Real-Time NextGen Chat</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div id="auth-container" class="glass-panel auth-wrapper">
    <h1>Welcome to NextGen Chat</h1>
    <div class="auth-tabs">
      <button id="tab-login" class="active">Login</button>
      <button id="tab-register">Register</button>
    </div>
    
    <form id="login-form">
      <input type="email" id="login-email" placeholder="Email" required>
      <input type="password" id="login-password" placeholder="Password" required>
      <button type="submit" class="btn-primary">Login</button>
    </form>
    
    <form id="register-form" style="display: none;">
      <input type="text" id="reg-username" placeholder="Username" required>
      <input type="email" id="reg-email" placeholder="Email" required>
      <input type="password" id="reg-password" placeholder="Password" required>
      <button type="submit" class="btn-primary">Register</button>
    </form>
    <div id="auth-error" class="error-msg"></div>
  </div>

  <div id="app-container" style="display: none;" class="layout-container">
    <aside class="sidebar glass-panel">
      <div class="user-profile">
        <h2 id="current-username">User</h2>
        <button id="logout-btn" class="btn-secondary">Logout</button>
      </div>
      <h3>Contacts</h3>
      <ul id="users-list"></ul>
    </aside>

    <main class="chat-area glass-panel">
      <header class="chat-header">
        <h2 id="chatting-with">Select a user to start chatting</h2>
        <div class="call-actions" id="call-actions" style="display: none;">
          <button id="audio-call-btn" class="btn-icon" title="Audio Call">📞</button>
          <button id="video-call-btn" class="btn-icon" title="Video Call">🎥</button>
        </div>
      </header>
      
      <div class="messages", id="messages-container">
        <!-- Messages will be injected here -->
      </div>
      
      <form id="message-form" style="display: none;">
        <input type="text" id="message-input" placeholder="Type a message..." autocomplete="off" required>
        <button type="submit" class="btn-primary">Send</button>
      </form>
    </main>

    <!-- Video Call Overlay -->
    <div id="call-overlay" class="overlay glass-panel" style="display: none;">
      <div class="video-container">
        <video id="remote-video" autoplay playsinline></video>
        <video id="local-video" autoplay muted playsinline></video>
      </div>
      <div class="call-controls">
        <h3 id="call-status">Calling...</h3>
        <button id="end-call-btn" class="btn-danger">End Call</button>
      </div>
    </div>
    
    <!-- Incoming Call Modal -->
    <div id="incoming-call-modal" class="modal glass-panel" style="display: none;">
      <h3 id="caller-name">Incoming call from...</h3>
      <div class="modal-actions">
        <button id="accept-call-btn" class="btn-success">Accept</button>
        <button id="reject-call-btn" class="btn-danger">Decline</button>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <!-- Simple-peer is a lightweight wrapper for WebRTC -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/simple-peer/9.11.1/simplepeer.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
