<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RealTime Chat</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- AUTHENTICATION VIEW -->
  <div id="auth-container" class="auth-wrapper">
    <h1>RealTime Chat</h1>
    <div class="auth-tabs">
      <button id="tab-login" class="active">Login</button>
      <button id="tab-register">Register</button>
    </div>
    
    <form id="login-form">
      <input type="email" id="login-email" placeholder="Email" required>
      <input type="password" id="login-password" placeholder="Password" required>
      <button type="submit" class="btn-primary">Login</button>
    </form>
    
    <form id="register-form" style="display: none;">
      <input type="text" id="reg-username" placeholder="Username" required>
      <input type="email" id="reg-email" placeholder="Email" required>
      <input type="password" id="reg-password" placeholder="Password" required>
      <button type="submit" class="btn-primary">Register</button>
    </form>
    <div id="auth-error" class="error-msg"></div>
  </div>

  <!-- MAIN APP VIEW -->
  <div id="app-container" style="display: none;" class="layout-container">
    
    <aside class="sidebar">
      <div class="user-profile">
        <div class="profile-info">
          <div class="profile-avatar">👤</div>
          <h2 id="current-username">User</h2>
        </div>
        <div style="display: flex; gap: 8px;">
          <button id="settings-btn" class="icon-btn" title="Settings">⚙️</button>
          <button id="logout-btn" class="icon-btn" title="Logout">🚪</button>
        </div>
      </div>
      
      <div class="search-bar">
        <input type="text" placeholder="Search or start new chat">
      </div>
      
      <ul id="users-list"></ul>
    </aside>


    <main class="chat-area">
      <header class="chat-header">
        <div class="chat-header-info" id="chat-header-info" style="visibility: hidden;">
          <button id="back-btn" class="icon-btn mobile-only" title="Back">⬅️</button>
          <div class="profile-avatar">👤</div>
          <div>
            <h2 id="chatting-with">Select a user</h2>
            <div id="chatting-status" class="status-indicator"></div>
          </div>
        </div>
        
        <div class="call-actions" id="call-actions" style="display: none;">
          <button id="video-call-btn" class="icon-btn" title="Video Call">🎥</button>
          <button id="audio-call-btn" class="icon-btn" title="Voice Call">📞</button>
        </div>
      </header>
      
      

      <div class="messages" id="messages-container">
        <!-- Messages will be injected here -->
      </div>
      
      <form id="message-form" style="display: none;">
        <button type="button" class="icon-btn">😊</button>
        <button type="button" class="icon-btn">📎</button>
        <input type="text" id="message-input" placeholder="Type a message" autocomplete="off" required>
        <button type="submit" class="icon-btn">➤</button>
      </form>
    </main>

    <!-- VIDEO CALL OVERLAY -->
    <div id="call-overlay" class="overlay" style="display: none;">
      <div class="call-header">
        <h3 id="call-overlay-name">Calling User...</h3>
        <p id="call-status">Connecting...</p>
      </div>
      <div class="video-container">
        <video id="remote-video" autoplay playsinline></video>
        <video id="local-video" autoplay muted playsinline></video>
      </div>
      <div class="call-controls">
        <button id="end-call-btn" class="call-btn end" title="End Call">📵</button>
      </div>
    </div>
    
    
    <!-- INCOMING CALL MODAL -->
    <div id="incoming-call-modal" class="modal-overlay" style="display: none;">
      <div class="call-modal">
        <div class="call-modal-avatar">👤</div>
        <h3 id="caller-name">User</h3>
        <p id="call-modal-type">Video Call</p>
        <div class="call-modal-actions">
          <button id="reject-call-btn" class="call-btn end">📵</button>
          <button id="accept-call-btn" class="call-btn accept">📞</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/simple-peer/9.11.1/simplepeer.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
